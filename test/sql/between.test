# name: test/sql/between.test
# description: BETWEEN expression round-trip coverage
# group: [sql]

require lpts

statement ok
CREATE TABLE between_items (id INTEGER, d DATE, amount INTEGER);

statement ok
INSERT INTO between_items VALUES (1, DATE '1997-01-01', 10), (2, DATE '1997-06-15', 20), (3, DATE '1998-01-01', 30);

query I
PRAGMA lpts_check('SELECT id, amount FROM between_items WHERE d BETWEEN DATE ''1997-01-01'' AND DATE ''1997-12-31'' ORDER BY id');
----
true

query I
PRAGMA lpts_check('SELECT id FROM between_items WHERE amount NOT BETWEEN 15 AND 25 ORDER BY id');
----
true
