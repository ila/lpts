# name: test/sql/distinct.test
# description: test lpts with SELECT DISTINCT queries
# group: [sql]

require lpts

statement ok
CREATE TABLE users (id INTEGER, name VARCHAR, age INTEGER);

# DISTINCT on a single column
query I
SELECT replace(sql, chr(10), ' ') FROM lpts_query('SELECT DISTINCT name FROM users');
----
WITH scan_0 (t0_name) AS (SELECT name FROM memory.main.users),  projection_1 (t1_name) AS (SELECT t0_name FROM scan_0),  distinct_2 (t1_name) AS (SELECT DISTINCT * FROM projection_1) SELECT t1_name AS name FROM distinct_2;

# DISTINCT with a WHERE filter
query I
SELECT replace(sql, chr(10), ' ') FROM lpts_query('SELECT DISTINCT name FROM users WHERE age > 18');
----
WITH scan_0 (t0_age, t0_name) AS (SELECT age, name FROM memory.main.users),  filter_1 AS (SELECT * FROM scan_0 WHERE (t0_age) > (CAST(18 AS INTEGER))),  projection_2 (t1_name) AS (SELECT t0_name FROM filter_1),  distinct_3 (t1_name) AS (SELECT DISTINCT * FROM projection_2) SELECT t1_name AS name FROM distinct_3;
