# name: test/sql/functions.test
# description: test lpts with scalar function calls (BOUND_FUNCTION expressions)
# group: [sql]

require lpts

statement ok
CREATE TABLE users (id INTEGER, name VARCHAR, age INTEGER);

statement ok
INSERT INTO users VALUES (1, 'Alice', 30), (2, 'Bob', 25), (3, 'Carol', 35), (4, 'dave', 22);

# --- length() in projection ---

query II rowsort
PRAGMA lpts_exec('SELECT name, length(name) FROM users');
----
Alice	5
Bob	3
Carol	5
dave	4

query I
PRAGMA lpts_check('SELECT name, length(name) FROM users');
----
true

# --- upper() in projection: string to uppercase ---

query I rowsort
PRAGMA lpts_exec('SELECT upper(name) FROM users');
----
ALICE
BOB
CAROL
DAVE

query I
PRAGMA lpts_check('SELECT upper(name) FROM users');
----
true

# --- lower() in projection ---

query I rowsort
PRAGMA lpts_exec('SELECT lower(name) FROM users');
----
alice
bob
carol
dave

query I
PRAGMA lpts_check('SELECT lower(name) FROM users');
----
true

# --- length() in WHERE filter ---

query II rowsort
PRAGMA lpts_exec('SELECT name, age FROM users WHERE length(name) > 3');
----
Alice	30
Carol	35
dave	22

query I
PRAGMA lpts_check('SELECT name, age FROM users WHERE length(name) > 3');
----
true

# --- upper() in projection + length() in WHERE filter combined ---

query II rowsort
PRAGMA lpts_exec('SELECT upper(name), age FROM users WHERE length(name) > 3');
----
ALICE	30
CAROL	35
DAVE	22

query I
PRAGMA lpts_check('SELECT upper(name), age FROM users WHERE length(name) > 3');
----
true

# --- Arithmetic operator (+) as a scalar function in projection ---

query II rowsort
PRAGMA lpts_exec('SELECT id, age + 1 FROM users');
----
1	31
2	26
3	36
4	23

query I
PRAGMA lpts_check('SELECT id, age + 1 FROM users');
----
true

# --- Arithmetic in filter: age - 5 > 20 ---

query I rowsort
PRAGMA lpts_exec('SELECT name FROM users WHERE age - 5 > 20');
----
Alice
Carol

query I
PRAGMA lpts_check('SELECT name FROM users WHERE age - 5 > 20');
----
true

# --- Nested scalar function: upper(lower(name)) ---

query I
PRAGMA lpts_check('SELECT upper(lower(name)) FROM users');
----
true

# --- Scalar function on a constant: length(''hello'') ---

query I
PRAGMA lpts_check('SELECT length(''hello'') FROM users');
----
true

# --- Function applied to integer arithmetic: abs(age - 30) ---

statement ok
CREATE TABLE scores (player VARCHAR, score INTEGER);

statement ok
INSERT INTO scores VALUES ('P1', 100), ('P2', -50), ('P3', 0), ('P4', 75);

query II rowsort
PRAGMA lpts_exec('SELECT player, abs(score) FROM scores');
----
P1	100
P2	50
P3	0
P4	75

query I
PRAGMA lpts_check('SELECT player, abs(score) FROM scores');
----
true

# --- Function in both projection and filter ---

query II rowsort
PRAGMA lpts_exec('SELECT player, abs(score) FROM scores WHERE abs(score) > 60');
----
P1	100
P4	75

query I
PRAGMA lpts_check('SELECT player, abs(score) FROM scores WHERE abs(score) > 60');
----
true

# --- Function on NULL input: length(NULL) → NULL ---

statement ok
CREATE TABLE nullnames (name VARCHAR);

statement ok
INSERT INTO nullnames VALUES ('hello'), (NULL);

query I rowsort
PRAGMA lpts_exec('SELECT length(name) FROM nullnames');
----
5
NULL

query I
PRAGMA lpts_check('SELECT length(name) FROM nullnames');
----
true
