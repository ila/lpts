# name: test/sql/group_by.test
# description: test lpts with GROUP BY / aggregate queries
# group: [sql]

require lpts

statement ok
CREATE TABLE sales (product VARCHAR, region VARCHAR, amount INTEGER);

statement ok
INSERT INTO sales VALUES
  ('A', 'EU', 100), ('A', 'EU', 200), ('A', 'US', 300),
  ('B', 'EU', 50),  ('B', 'US', 400), ('B', 'US', 150);

# --- Scalar aggregate: COUNT(*) with no GROUP BY ---

query I
PRAGMA lpts_exec('SELECT count(*) FROM sales');
----
6

query I
PRAGMA lpts_check('SELECT count(*) FROM sales');
----
true

# --- Scalar aggregate: SUM over entire table ---

query I
PRAGMA lpts_exec('SELECT sum(amount) FROM sales');
----
1200

query I
PRAGMA lpts_check('SELECT sum(amount) FROM sales');
----
true

# --- Scalar aggregate: MIN and MAX ---

query I
PRAGMA lpts_check('SELECT min(amount) FROM sales');
----
true

query I
PRAGMA lpts_check('SELECT max(amount) FROM sales');
----
true

# --- GROUP BY single column with COUNT ---

query II rowsort
PRAGMA lpts_exec('SELECT product, count(*) FROM sales GROUP BY product');
----
A	3
B	3

query I
PRAGMA lpts_check('SELECT product, count(*) FROM sales GROUP BY product');
----
true

# --- GROUP BY single column with SUM ---

query II rowsort
PRAGMA lpts_exec('SELECT region, sum(amount) FROM sales GROUP BY region');
----
EU	350
US	850

query I
PRAGMA lpts_check('SELECT region, sum(amount) FROM sales GROUP BY region');
----
true

# --- GROUP BY single column with AVG ---

query I
PRAGMA lpts_check('SELECT product, avg(amount) FROM sales GROUP BY product');
----
true

# --- GROUP BY single column with MIN / MAX ---

query I
PRAGMA lpts_check('SELECT region, min(amount), max(amount) FROM sales GROUP BY region');
----
true

# --- GROUP BY multiple columns ---

query III rowsort
PRAGMA lpts_exec('SELECT product, region, count(*) FROM sales GROUP BY product, region');
----
A	EU	2
A	US	1
B	EU	1
B	US	2

query I
PRAGMA lpts_check('SELECT product, region, count(*) FROM sales GROUP BY product, region');
----
true

# --- GROUP BY with WHERE: filter applied before aggregation ---

query II rowsort
PRAGMA lpts_exec('SELECT product, count(*) FROM sales WHERE amount > 100 GROUP BY product');
----
A	2
B	2

query I
PRAGMA lpts_check('SELECT product, count(*) FROM sales WHERE amount > 100 GROUP BY product');
----
true

# --- GROUP BY with multiple aggregates in the same query ---

query I
PRAGMA lpts_check('SELECT product, count(*), sum(amount), min(amount), max(amount) FROM sales GROUP BY product');
----
true

# --- COUNT(DISTINCT col): de-duplicates before counting ---

query II rowsort
PRAGMA lpts_exec('SELECT region, count(DISTINCT product) FROM sales GROUP BY region');
----
EU	2
US	2

query I
PRAGMA lpts_check('SELECT region, count(DISTINCT product) FROM sales GROUP BY region');
----
true

# --- GROUP BY on a table with a single group (all rows same key) ---

statement ok
CREATE TABLE uniform (grp VARCHAR, val INTEGER);

statement ok
INSERT INTO uniform VALUES ('X', 1), ('X', 2), ('X', 3);

query II
PRAGMA lpts_exec('SELECT grp, sum(val) FROM uniform GROUP BY grp');
----
X	6

query I
PRAGMA lpts_check('SELECT grp, sum(val) FROM uniform GROUP BY grp');
----
true

# --- GROUP BY on empty table: no groups, no rows ---

statement ok
CREATE TABLE empty_sales (product VARCHAR, amount INTEGER);

query II
PRAGMA lpts_exec('SELECT product, count(*) FROM empty_sales GROUP BY product');
----

query I
PRAGMA lpts_check('SELECT product, count(*) FROM empty_sales GROUP BY product');
----
true

# --- COUNT(*) on empty table returns 0 ---

query I
PRAGMA lpts_exec('SELECT count(*) FROM empty_sales');
----
0

query I
PRAGMA lpts_check('SELECT count(*) FROM empty_sales');
----
true

# --- GROUP BY with NULL values: NULLs form their own group ---

statement ok
CREATE TABLE nullable_grp (cat VARCHAR, val INTEGER);

statement ok
INSERT INTO nullable_grp VALUES ('A', 10), (NULL, 20), (NULL, 30), ('A', 5);

query I
PRAGMA lpts_check('SELECT cat, sum(val) FROM nullable_grp GROUP BY cat');
----
true

# --- Aggregate ignores NULLs: SUM(NULL-containing col) ---

statement ok
CREATE TABLE with_nulls (grp VARCHAR, val INTEGER);

statement ok
INSERT INTO with_nulls VALUES ('A', 10), ('A', NULL), ('B', NULL), ('B', NULL);

query II rowsort
PRAGMA lpts_exec('SELECT grp, sum(val) FROM with_nulls GROUP BY grp');
----
A	10
B	NULL

query I
PRAGMA lpts_check('SELECT grp, sum(val) FROM with_nulls GROUP BY grp');
----
true
