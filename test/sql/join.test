# name: test/sql/join.test
# description: test lpts with JOIN queries
# group: [sql]

require lpts

statement ok
CREATE TABLE users (id INTEGER, name VARCHAR);

statement ok
CREATE TABLE orders (id INTEGER, user_id INTEGER, amount DECIMAL);

statement ok
INSERT INTO users VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Carol');

statement ok
INSERT INTO orders VALUES (1, 1, 100.0), (2, 1, 200.0), (3, 2, 150.0);

# --- INNER JOIN: only rows with matches on both sides ---

query II rowsort
PRAGMA lpts_exec('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id');
----
Alice	100.0
Alice	200.0
Bob	150.0

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id');
----
true

# --- INNER JOIN with filter: WHERE applied after join ---

query II rowsort
PRAGMA lpts_exec('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id WHERE o.amount > 100');
----
Alice	200.0
Bob	150.0

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id WHERE o.amount > 100');
----
true

# --- LEFT JOIN: all left rows kept; Carol has no orders so amount is NULL ---

query II rowsort
PRAGMA lpts_exec('SELECT u.name, o.amount FROM users u LEFT JOIN orders o ON u.id = o.user_id');
----
Alice	100.0
Alice	200.0
Bob	150.0
Carol	NULL

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u LEFT JOIN orders o ON u.id = o.user_id');
----
true

# --- LEFT JOIN with IS NULL: find users with no orders ---

query I
PRAGMA lpts_exec('SELECT u.name FROM users u LEFT JOIN orders o ON u.id = o.user_id WHERE o.id IS NULL');
----
Carol

query I
PRAGMA lpts_check('SELECT u.name FROM users u LEFT JOIN orders o ON u.id = o.user_id WHERE o.id IS NULL');
----
true

# --- RIGHT JOIN: DuckDB rewrites internally; all order rows kept ---

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u RIGHT JOIN orders o ON u.id = o.user_id');
----
true

# --- FULL OUTER JOIN: all rows from both sides ---

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u FULL OUTER JOIN orders o ON u.id = o.user_id');
----
true

# --- JOIN with computed expression in projection ---

statement ok
CREATE TABLE staff (id INTEGER, dept VARCHAR, salary INTEGER);

statement ok
CREATE TABLE bonus (dept VARCHAR, amount INTEGER);

statement ok
INSERT INTO staff VALUES (1, 'eng', 50000), (2, 'sales', 60000), (3, 'eng', 55000);

statement ok
INSERT INTO bonus VALUES ('eng', 5000), ('sales', 6000);

query II rowsort
PRAGMA lpts_exec('SELECT s.id, s.salary + b.amount FROM staff s JOIN bonus b ON s.dept = b.dept');
----
1	55000
2	66000
3	60000

query I
PRAGMA lpts_check('SELECT s.id, s.salary + b.amount FROM staff s JOIN bonus b ON s.dept = b.dept');
----
true

# --- JOIN on string column ---

query II rowsort
PRAGMA lpts_exec('SELECT s.dept, s.salary FROM staff s JOIN bonus b ON s.dept = b.dept');
----
eng	50000
eng	55000
sales	60000

query I
PRAGMA lpts_check('SELECT s.dept, s.salary FROM staff s JOIN bonus b ON s.dept = b.dept');
----
true

# --- JOIN with GROUP BY on joined result ---

query II rowsort
PRAGMA lpts_exec('SELECT s.dept, sum(s.salary) FROM staff s JOIN bonus b ON s.dept = b.dept GROUP BY s.dept');
----
eng	105000
sales	60000

query I
PRAGMA lpts_check('SELECT s.dept, sum(s.salary) FROM staff s JOIN bonus b ON s.dept = b.dept GROUP BY s.dept');
----
true

# --- Self-join: join a table with itself ---

query I
PRAGMA lpts_check('SELECT a.name, b.name FROM users a JOIN users b ON a.id != b.id AND a.id < b.id');
----
true

# --- CROSS JOIN: Cartesian product ---

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u CROSS JOIN orders o');
----
true

# --- Implicit join syntax (comma): equivalent to CROSS JOIN ---

query I
PRAGMA lpts_check('SELECT u.name, s.salary FROM users u, staff s');
----
true

# --- Three-way JOIN ---

query I
PRAGMA lpts_check('SELECT u.name, o.amount, s.salary FROM users u JOIN orders o ON u.id = o.user_id JOIN staff s ON u.id = s.id');
----
true

# --- UNION ALL of two JOIN results ---

query II rowsort
PRAGMA lpts_exec('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id UNION ALL SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id');
----
Alice	100.0
Alice	100.0
Alice	200.0
Alice	200.0
Bob	150.0
Bob	150.0

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id UNION ALL SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id');
----
true
