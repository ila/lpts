# name: test/sql/join.test
# description: test lpts with JOIN queries
# group: [sql]

require lpts

statement ok
CREATE TABLE users (id INTEGER, name VARCHAR);

statement ok
CREATE TABLE orders (id INTEGER, user_id INTEGER, amount DECIMAL);

statement ok
INSERT INTO users VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Carol');

statement ok
INSERT INTO orders VALUES (1, 1, 100.0), (2, 1, 200.0), (3, 2, 150.0);

# --- INNER JOIN: only rows with matches on both sides ---

query II rowsort
PRAGMA lpts_exec('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id');
----
Alice	100.0
Alice	200.0
Bob	150.0

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id');
----
true

# --- INNER JOIN with filter: WHERE applied after join ---

query II rowsort
PRAGMA lpts_exec('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id WHERE o.amount > 100');
----
Alice	200.0
Bob	150.0

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id WHERE o.amount > 100');
----
true

# --- LEFT JOIN: all left rows kept; Carol has no orders so amount is NULL ---

query II rowsort
PRAGMA lpts_exec('SELECT u.name, o.amount FROM users u LEFT JOIN orders o ON u.id = o.user_id');
----
Alice	100.0
Alice	200.0
Bob	150.0
Carol	NULL

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u LEFT JOIN orders o ON u.id = o.user_id');
----
true

# --- LEFT JOIN with IS NULL: find users with no orders ---

query I
PRAGMA lpts_exec('SELECT u.name FROM users u LEFT JOIN orders o ON u.id = o.user_id WHERE o.id IS NULL');
----
Carol

query I
PRAGMA lpts_check('SELECT u.name FROM users u LEFT JOIN orders o ON u.id = o.user_id WHERE o.id IS NULL');
----
true

# --- RIGHT JOIN: DuckDB rewrites internally; all order rows kept ---

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u RIGHT JOIN orders o ON u.id = o.user_id');
----
true

# --- FULL OUTER JOIN: all rows from both sides ---

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u FULL OUTER JOIN orders o ON u.id = o.user_id');
----
true

# --- JOIN with computed expression in projection ---

statement ok
CREATE TABLE staff (id INTEGER, dept VARCHAR, salary INTEGER);

statement ok
CREATE TABLE bonus (dept VARCHAR, amount INTEGER);

statement ok
INSERT INTO staff VALUES (1, 'eng', 50000), (2, 'sales', 60000), (3, 'eng', 55000);

statement ok
INSERT INTO bonus VALUES ('eng', 5000), ('sales', 6000);

query II rowsort
PRAGMA lpts_exec('SELECT s.id, s.salary + b.amount FROM staff s JOIN bonus b ON s.dept = b.dept');
----
1	55000
2	66000
3	60000

query I
PRAGMA lpts_check('SELECT s.id, s.salary + b.amount FROM staff s JOIN bonus b ON s.dept = b.dept');
----
true

# --- JOIN on string column ---

query II rowsort
PRAGMA lpts_exec('SELECT s.dept, s.salary FROM staff s JOIN bonus b ON s.dept = b.dept');
----
eng	50000
eng	55000
sales	60000

query I
PRAGMA lpts_check('SELECT s.dept, s.salary FROM staff s JOIN bonus b ON s.dept = b.dept');
----
true

# --- JOIN with GROUP BY on joined result ---

query II rowsort
PRAGMA lpts_exec('SELECT s.dept, sum(s.salary) FROM staff s JOIN bonus b ON s.dept = b.dept GROUP BY s.dept');
----
eng	105000
sales	60000

query I
PRAGMA lpts_check('SELECT s.dept, sum(s.salary) FROM staff s JOIN bonus b ON s.dept = b.dept GROUP BY s.dept');
----
true

# --- Self-join: join a table with itself ---

query I
PRAGMA lpts_check('SELECT a.name, b.name FROM users a JOIN users b ON a.id != b.id AND a.id < b.id');
----
true

# Duplicate column names across tables (projection deduplication)
query I
PRAGMA lpts_check('SELECT u.id, o.id FROM users u INNER JOIN orders o ON u.id = o.user_id');
----
true

query I
PRAGMA lpts_check('SELECT u.id, o.id, s.id FROM users u, orders o, staff s');
----
true

# Self-join (same table twice — same column names)
query I
PRAGMA lpts_check('SELECT a.id, b.id, a.name FROM users a INNER JOIN users b ON a.id = b.id');
----
true

# --- CROSS JOIN: Cartesian product ---
query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u CROSS JOIN orders o');
----
true

# --- Implicit join syntax (comma): equivalent to CROSS JOIN ---

query I
PRAGMA lpts_check('SELECT u.name, s.salary FROM users u, staff s');
----
true

# --- Three-way JOIN ---

query I
PRAGMA lpts_check('SELECT u.name, o.amount, s.salary FROM users u JOIN orders o ON u.id = o.user_id JOIN staff s ON u.id = s.id');
----
true

# --- UNION ALL of two JOIN results ---

query II rowsort
PRAGMA lpts_exec('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id UNION ALL SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id');
----
Alice	100.0
Alice	100.0
Alice	200.0
Alice	200.0
Bob	150.0
Bob	150.0

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id UNION ALL SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id');
----
true

# ============================================================
# MARK JOIN: IN subquery
# ============================================================

statement ok
CREATE TABLE t1 (id INTEGER, val INTEGER);

statement ok
CREATE TABLE t2 (id INTEGER);

statement ok
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);

statement ok
INSERT INTO t2 VALUES (1), (3);

# --- IN subquery: rows in t1 whose id appears in t2 ---

query II rowsort
PRAGMA lpts_exec('SELECT id, val FROM t1 WHERE id IN (SELECT id FROM t2)');
----
1	10
3	30

query I
PRAGMA lpts_check('SELECT id, val FROM t1 WHERE id IN (SELECT id FROM t2)');
----
true

# --- NOT IN subquery: rows in t1 whose id does not appear in t2 ---

query II
PRAGMA lpts_exec('SELECT id, val FROM t1 WHERE id NOT IN (SELECT id FROM t2)');
----
2	20

query I
PRAGMA lpts_check('SELECT id, val FROM t1 WHERE id NOT IN (SELECT id FROM t2)');
----
true

# --- IN subquery with aggregate ---

query I
PRAGMA lpts_check('SELECT id FROM t1 WHERE id IN (SELECT MAX(id) FROM t2)');
----
true

# ============================================================
# MARK JOIN: duplicate RHS values must not produce extra rows
# ============================================================
# LPTS converts MARK join to LEFT JOIN + WHERE (rhs IS NOT NULL).
# The right side is wrapped in SELECT DISTINCT to prevent left-row
# multiplication when the RHS has repeated values — IN subquery
# semantics treat the RHS as a set so duplicates must be ignored.

statement ok
CREATE TABLE t2_dups (id INTEGER);

statement ok
INSERT INTO t2_dups VALUES (1), (1), (3);

# Without SELECT DISTINCT on the RHS, id=1 would appear twice in the output.
query II rowsort
PRAGMA lpts_exec('SELECT id, val FROM t1 WHERE id IN (SELECT id FROM t2_dups)');
----
1	10
3	30

query I
PRAGMA lpts_check('SELECT id, val FROM t1 WHERE id IN (SELECT id FROM t2_dups)');
----
true

# ============================================================
# LOGICAL_EMPTY_RESULT: optimizer collapses to empty
# ============================================================

# --- LIMIT 0 on a join ---

query I
PRAGMA lpts_check('SELECT t1.id, t2.id FROM t1 JOIN t2 ON t1.id = t2.id LIMIT 0');
----
true

query II
PRAGMA lpts_exec('SELECT t1.id, t2.id FROM t1 JOIN t2 ON t1.id = t2.id LIMIT 0');
----

# --- Unsatisfiable WHERE clause ---

query I
PRAGMA lpts_check('SELECT id, val FROM t1 WHERE 1 = 2');
----
true

query II
PRAGMA lpts_exec('SELECT id, val FROM t1 WHERE 1 = 2');
----

# --- Empty result on one side of a JOIN ---

query I
PRAGMA lpts_check('SELECT t1.id FROM t1 JOIN (SELECT id FROM t2 WHERE 1 = 2) sub ON t1.id = sub.id');
----
true

query I
PRAGMA lpts_exec('SELECT t1.id FROM t1 JOIN (SELECT id FROM t2 WHERE 1 = 2) sub ON t1.id = sub.id');
----

# --- Empty result with multiple column types ---

statement ok
CREATE TABLE typed (a INTEGER, b VARCHAR, c DOUBLE, d BOOLEAN);

statement ok
INSERT INTO typed VALUES (1, 'hello', 3.14, true);

query I
PRAGMA lpts_check('SELECT a, b, c, d FROM typed LIMIT 0');
----
true

query ITRI
PRAGMA lpts_exec('SELECT a, b, c, d FROM typed LIMIT 0');
----
