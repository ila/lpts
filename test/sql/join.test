# name: test/sql/join.test
# description: test lpts with JOIN queries
# group: [sql]

require lpts

statement ok
CREATE TABLE users (id INTEGER, name VARCHAR);

statement ok
CREATE TABLE orders (id INTEGER, user_id INTEGER, amount DECIMAL);

# Inner join
query I
SELECT replace(sql, chr(10), ' ') FROM lpts_query('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id');
----
WITH scan_0 (t0_id, t0_name) AS (SELECT id, name FROM memory.main.users),  scan_1 (t1_user_id, t1_amount) AS (SELECT user_id, amount FROM memory.main.orders),  join_2 (t0_id, t0_name, t1_user_id, t1_amount) AS (SELECT t0_id, t0_name, t1_user_id, t1_amount FROM scan_0 INNER JOIN scan_1 ON (t0_id = t1_user_id)),  projection_3 (t2_name, t2_amount) AS (SELECT t0_name, t1_amount FROM join_2) SELECT t2_name AS name, t2_amount AS amount FROM projection_3;

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id');
----
true

# Left join
query I
SELECT replace(sql, chr(10), ' ') FROM lpts_query('SELECT u.name, o.amount FROM users u LEFT JOIN orders o ON u.id = o.user_id');
----
WITH scan_0 (t0_id, t0_name) AS (SELECT id, name FROM memory.main.users),  scan_1 (t1_user_id, t1_amount) AS (SELECT user_id, amount FROM memory.main.orders),  join_2 (t0_id, t0_name, t1_user_id, t1_amount) AS (SELECT t0_id, t0_name, t1_user_id, t1_amount FROM scan_0 LEFT JOIN scan_1 ON (t0_id = t1_user_id)),  projection_3 (t2_name, t2_amount) AS (SELECT t0_name, t1_amount FROM join_2) SELECT t2_name AS name, t2_amount AS amount FROM projection_3;

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u LEFT JOIN orders o ON u.id = o.user_id');
----
true

# Right join (DuckDB rewrites to flipped LEFT JOIN internally)
query I
SELECT replace(sql, chr(10), ' ') FROM lpts_query('SELECT u.name, o.amount FROM users u RIGHT JOIN orders o ON u.id = o.user_id');
----
WITH scan_0 (t1_user_id, t1_amount) AS (SELECT user_id, amount FROM memory.main.orders),  scan_1 (t0_id, t0_name) AS (SELECT id, name FROM memory.main.users),  join_2 (t1_user_id, t1_amount, t0_id, t0_name) AS (SELECT t1_user_id, t1_amount, t0_id, t0_name FROM scan_0 LEFT JOIN scan_1 ON (t1_user_id = t0_id)),  projection_3 (t2_name, t2_amount) AS (SELECT t0_name, t1_amount FROM join_2) SELECT t2_name AS name, t2_amount AS amount FROM projection_3;

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u RIGHT JOIN orders o ON u.id = o.user_id');
----
true

# Full outer join
query I
SELECT replace(sql, chr(10), ' ') FROM lpts_query('SELECT u.name, o.amount FROM users u FULL OUTER JOIN orders o ON u.id = o.user_id');
----
WITH scan_0 (t0_id, t0_name) AS (SELECT id, name FROM memory.main.users),  scan_1 (t1_user_id, t1_amount) AS (SELECT user_id, amount FROM memory.main.orders),  join_2 (t0_id, t0_name, t1_user_id, t1_amount) AS (SELECT t0_id, t0_name, t1_user_id, t1_amount FROM scan_0 FULL JOIN scan_1 ON (t0_id = t1_user_id)),  projection_3 (t2_name, t2_amount) AS (SELECT t0_name, t1_amount FROM join_2) SELECT t2_name AS name, t2_amount AS amount FROM projection_3;

query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u FULL OUTER JOIN orders o ON u.id = o.user_id');
----
true

# Join with computed expressions (verifies column alignment with same-name join keys)
statement ok
CREATE TABLE staff (id INTEGER, dept VARCHAR, salary INTEGER);

statement ok
CREATE TABLE bonus (dept VARCHAR, amount INTEGER);

query I
PRAGMA lpts_check('SELECT s.id, s.salary + b.amount FROM staff s JOIN bonus b ON s.dept = b.dept');
----
true

# Union all
query I
SELECT replace(sql, chr(10), ' ') FROM lpts_query('SELECT id, name FROM users UNION ALL SELECT id, name FROM users');
----
WITH scan_0 (t1_id, t1_name) AS (SELECT id, name FROM memory.main.users),  projection_1 (t2_id, t2_name) AS (SELECT t1_id, t1_name FROM scan_0),  scan_2 (t8_id, t8_name) AS (SELECT id, name FROM memory.main.users),  projection_3 (t9_id, t9_name) AS (SELECT t8_id, t8_name FROM scan_2),  union_4 (t0_id, t0_name) AS (SELECT * FROM projection_1 UNION ALL SELECT * FROM projection_3) SELECT t0_id AS id, t0_name AS name FROM union_4;

query I
PRAGMA lpts_check('SELECT id, name FROM users UNION ALL SELECT id, name FROM users');
----
true

# Duplicate column names across tables (projection deduplication)
query I
PRAGMA lpts_check('SELECT u.id, o.id FROM users u INNER JOIN orders o ON u.id = o.user_id');
----
true

query I
PRAGMA lpts_check('SELECT u.id, o.id, s.id FROM users u, orders o, staff s');
----
true

# Self-join (same table twice — same column names)
query I
PRAGMA lpts_check('SELECT a.id, b.id, a.name FROM users a INNER JOIN users b ON a.id = b.id');
----
true

# CROSS JOIN / CROSS PRODUCT
query I
PRAGMA lpts_check('SELECT u.name, o.amount FROM users u CROSS JOIN orders o');
----
true

query I
PRAGMA lpts_check('SELECT u.name, s.salary FROM users u, staff s');
----
true
