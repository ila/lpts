# name: test/sql/lambda.test
# description: test lpts with lambda expressions (list_transform, list_filter, list_reduce)
# group: [sql]

require lpts

statement ok
CREATE TABLE items (id INT, grp INT, val FLOAT[]);

statement ok
INSERT INTO items VALUES
  (1, 1, [1.0, 2.0, 3.0]),
  (2, 1, [4.0, 5.0]),
  (3, 2, [10.0, 20.0]),
  (4, 2, [7.0]),
  (5, 3, []);

# --- list_transform: add scalar to each element ---

query II rowsort
PRAGMA lpts_exec('SELECT grp, list_transform(val, lambda x: x + 1.0) FROM items');
----
1	[2.0, 3.0, 4.0]
1	[5.0, 6.0]
2	[11.0, 21.0]
2	[8.0]
3	[]

query I
PRAGMA lpts_check('SELECT grp, list_transform(val, lambda x: x + 1.0) FROM items');
----
true

# --- list_transform: multiply by scalar ---

query I
PRAGMA lpts_check('SELECT grp, list_transform(val, lambda x: x * 2.0) FROM items');
----
true

# --- list_transform on single-element list ---

query II
PRAGMA lpts_exec('SELECT id, list_transform(val, lambda x: x + 10.0) FROM items WHERE id = 4');
----
4	[17.0]

query I
PRAGMA lpts_check('SELECT id, list_transform(val, lambda x: x + 10.0) FROM items WHERE id = 4');
----
true

# --- list_transform on empty list: returns empty list ---

query II
PRAGMA lpts_exec('SELECT id, list_transform(val, lambda x: x + 1.0) FROM items WHERE id = 5');
----
5	[]

query I
PRAGMA lpts_check('SELECT id, list_transform(val, lambda x: x + 1.0) FROM items WHERE id = 5');
----
true

# --- list_filter: retain elements matching condition ---

query II rowsort
PRAGMA lpts_exec('SELECT grp, list_filter(val, lambda x: x > 5.0) FROM items');
----
1	[]
1	[]
2	[10.0, 20.0]
2	[7.0]
3	[]

query I
PRAGMA lpts_check('SELECT grp, list_filter(val, lambda x: x > 5.0) FROM items');
----
true

# --- list_filter: condition retains all elements ---

query I
PRAGMA lpts_check('SELECT list_filter(val, lambda x: x >= 0.0) FROM items');
----
true

# --- list_filter: condition retains no elements ---

query I
PRAGMA lpts_check('SELECT list_filter(val, lambda x: x > 999.0) FROM items');
----
true

# --- list_filter on empty list: returns empty list ---

query II
PRAGMA lpts_exec('SELECT id, list_filter(val, lambda x: x > 0.0) FROM items WHERE id = 5');
----
5	[]

query I
PRAGMA lpts_check('SELECT id, list_filter(val, lambda x: x > 0.0) FROM items WHERE id = 5');
----
true

# --- list_transform with compound body expression ---

query I
PRAGMA lpts_check('SELECT list_transform(val, lambda x: x * x) FROM items');
----
true

# --- list_reduce with two-param lambda: element-wise sum across rows in a group ---

query II rowsort
PRAGMA lpts_exec('SELECT grp, list_reduce(list(val), lambda a, b: list_transform(list_zip(a, b), lambda x: x[1] + x[2])) AS total FROM items GROUP BY grp');
----
1	[5.0, 7.0, NULL]
2	[17.0, NULL]
3	[]

query I
PRAGMA lpts_check('SELECT grp, list_reduce(list(val), lambda a, b: list_transform(list_zip(a, b), lambda x: x[1] + x[2])) AS total FROM items GROUP BY grp');
----
true

# --- list_transform combined with WHERE filter ---

query II rowsort
PRAGMA lpts_exec('SELECT id, list_transform(val, lambda x: x + 1.0) FROM items WHERE grp = 2');
----
3	[11.0, 21.0]
4	[8.0]

query I
PRAGMA lpts_check('SELECT id, list_transform(val, lambda x: x + 1.0) FROM items WHERE grp = 2');
----
true

# --- Lambda in aggregate context: list() + list_transform ---

query I
PRAGMA lpts_check('SELECT grp, list_transform(list(id), lambda x: x + 100) FROM items GROUP BY grp');
----
true
