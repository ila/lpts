# name: test/sql/operators.test
# description: test lpts with BOUND_OPERATOR (IS NULL, IS NOT NULL, IN, NOT IN, NOT, COALESCE, NULLIF) and BOUND_CASE (CASE WHEN)
# group: [sql]

require lpts

statement ok
CREATE TABLE t (id INTEGER, val INTEGER, name VARCHAR);

statement ok
INSERT INTO t VALUES (1, 10, 'Alice'), (2, NULL, 'Bob'), (3, 30, NULL), (4, 20, 'Dave');

# ============================================================
# IS NULL / IS NOT NULL
# ============================================================

# --- IS NULL in WHERE filter ---

query I
PRAGMA lpts_exec('SELECT id FROM t WHERE val IS NULL');
----
2

query I
PRAGMA lpts_check('SELECT id FROM t WHERE val IS NULL');
----
true

# --- IS NOT NULL in WHERE filter ---

query I rowsort
PRAGMA lpts_exec('SELECT id FROM t WHERE name IS NOT NULL');
----
1
2
4

query I
PRAGMA lpts_check('SELECT id FROM t WHERE name IS NOT NULL');
----
true

# --- IS NULL on projected expression ---

query I
PRAGMA lpts_check('SELECT id, val IS NULL AS is_missing FROM t');
----
true

# ============================================================
# IN / NOT IN
# ============================================================

# --- IN with literal list ---

query I rowsort
PRAGMA lpts_exec('SELECT id FROM t WHERE val IN (10, 30)');
----
1
3

query I
PRAGMA lpts_check('SELECT id FROM t WHERE val IN (10, 30)');
----
true

# --- NOT IN with literal list ---

query I
PRAGMA lpts_exec('SELECT id FROM t WHERE val NOT IN (10, 30)');
----
4

query I
PRAGMA lpts_check('SELECT id FROM t WHERE val NOT IN (10, 30)');
----
true

# --- IN with single value ---

query I
PRAGMA lpts_exec('SELECT id FROM t WHERE val IN (20)');
----
4

query I
PRAGMA lpts_check('SELECT id FROM t WHERE val IN (20)');
----
true

# ============================================================
# NOT operator
# ============================================================

# --- NOT (IS NULL) ---

query I rowsort
PRAGMA lpts_exec('SELECT id FROM t WHERE NOT (val IS NULL)');
----
1
3
4

query I
PRAGMA lpts_check('SELECT id FROM t WHERE NOT (val IS NULL)');
----
true

# --- NOT with comparison ---

query I rowsort
PRAGMA lpts_exec('SELECT id FROM t WHERE NOT (val > 15)');
----
1

query I
PRAGMA lpts_check('SELECT id FROM t WHERE NOT (val > 15)');
----
true

# ============================================================
# COALESCE
# ============================================================

# --- COALESCE in projection ---

query II rowsort
PRAGMA lpts_exec('SELECT id, COALESCE(val, 0) AS v FROM t');
----
1	10
2	0
3	30
4	20

query I
PRAGMA lpts_check('SELECT id, COALESCE(val, 0) AS v FROM t');
----
true

# --- COALESCE in WHERE filter ---

query II rowsort
PRAGMA lpts_exec('SELECT id, COALESCE(val, 0) AS v FROM t WHERE COALESCE(val, 0) > 15');
----
3	30
4	20

query I
PRAGMA lpts_check('SELECT id, COALESCE(val, 0) AS v FROM t WHERE COALESCE(val, 0) > 15');
----
true

# ============================================================
# NULLIF
# ============================================================

# --- NULLIF in projection ---

query II rowsort
PRAGMA lpts_exec('SELECT id, NULLIF(val, 10) AS v FROM t');
----
1	NULL
2	NULL
3	30
4	20

query I
PRAGMA lpts_check('SELECT id, NULLIF(val, 10) AS v FROM t');
----
true

# ============================================================
# CASE WHEN (BOUND_CASE)
# ============================================================

# --- CASE WHEN with two branches and ELSE ---

query II rowsort
PRAGMA lpts_exec('SELECT id, CASE WHEN val > 25 THEN ''high'' WHEN val > 10 THEN ''mid'' ELSE ''low'' END AS band FROM t');
----
1	low
2	low
3	high
4	mid

query I
PRAGMA lpts_check('SELECT id, CASE WHEN val > 25 THEN ''high'' WHEN val > 10 THEN ''mid'' ELSE ''low'' END AS band FROM t');
----
true

# --- CASE WHEN with IS NULL check ---

query II rowsort
PRAGMA lpts_exec('SELECT id, CASE WHEN val IS NULL THEN 0 ELSE val END AS safe_val FROM t');
----
1	10
2	0
3	30
4	20

query I
PRAGMA lpts_check('SELECT id, CASE WHEN val IS NULL THEN 0 ELSE val END AS safe_val FROM t');
----
true

# --- CASE WHEN in WHERE (via aggregate) ---

query I
PRAGMA lpts_check('SELECT sum(CASE WHEN val > 10 THEN val ELSE 0 END) FROM t');
----
true

# --- CASE WHEN in GROUP BY aggregate ---

statement ok
CREATE TABLE orders (region VARCHAR, amount INTEGER, priority VARCHAR);

statement ok
INSERT INTO orders VALUES
  ('US', 100, '1-URGENT'), ('US', 200, '2-HIGH'), ('US', 50, '3-LOW'),
  ('EU', 300, '1-URGENT'), ('EU', 150, '3-LOW');

query II rowsort
PRAGMA lpts_exec('SELECT region, sum(CASE WHEN priority = ''1-URGENT'' THEN amount ELSE 0 END) AS urgent_total FROM orders GROUP BY region');
----
EU	300
US	100

query I
PRAGMA lpts_check('SELECT region, sum(CASE WHEN priority = ''1-URGENT'' THEN amount ELSE 0 END) AS urgent_total FROM orders GROUP BY region');
----
true

# ============================================================
# Combined: CASE + IN
# ============================================================

query I
PRAGMA lpts_check('SELECT id, CASE WHEN val IN (10, 20) THEN ''small'' ELSE ''large'' END AS sz FROM t');
----
true

# ============================================================
# Postgres dialect: table reference without catalog/schema prefix
# ============================================================

query I
SELECT sql LIKE '%memory.main.t%' AS uses_catalog FROM lpts_query('SELECT id FROM t WHERE val IS NULL');
----
true

statement ok
SET lpts_dialect = 'postgres';

query I
SELECT sql LIKE '%memory.main.t%' AS uses_catalog FROM lpts_query('SELECT id FROM t WHERE val IS NULL');
----
false

query I
PRAGMA lpts_check('SELECT id FROM t WHERE val IS NULL');
----
true

statement ok
SET lpts_dialect = 'duckdb';
