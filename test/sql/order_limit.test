# name: test/sql/order_limit.test
# description: test lpts with ORDER BY and LIMIT/OFFSET queries
# group: [sql]

require lpts

statement ok
CREATE TABLE users (id INTEGER, name VARCHAR, age INTEGER);

statement ok
INSERT INTO users VALUES (1, 'Alice', 30), (2, 'Bob', 25), (3, 'Carol', 35), (4, 'Dave', 25), (5, 'Eve', 30);

# --- ORDER BY single column DESC ---

query III
PRAGMA lpts_exec('SELECT id, name, age FROM users ORDER BY age DESC');
----
3	Carol	35
1	Alice	30
5	Eve	30
2	Bob	25
4	Dave	25

query I
PRAGMA lpts_check('SELECT id, name, age FROM users ORDER BY age DESC');
----
true

# --- ORDER BY single column ASC (default) ---

query III
PRAGMA lpts_exec('SELECT id, name, age FROM users ORDER BY age ASC');
----
2	Bob	25
4	Dave	25
1	Alice	30
5	Eve	30
3	Carol	35

query I
PRAGMA lpts_check('SELECT id, name, age FROM users ORDER BY age ASC');
----
true

# --- ORDER BY multiple columns: primary sort age DESC, secondary name ASC for ties ---

query III
PRAGMA lpts_exec('SELECT id, name, age FROM users ORDER BY age DESC, name ASC');
----
3	Carol	35
1	Alice	30
5	Eve	30
2	Bob	25
4	Dave	25

query I
PRAGMA lpts_check('SELECT id, name, age FROM users ORDER BY age DESC, name ASC');
----
true

# --- ORDER BY: sort on a column not in SELECT ---

query II
PRAGMA lpts_exec('SELECT id, name FROM users ORDER BY age DESC, name ASC');
----
3	Carol
1	Alice
5	Eve
2	Bob
4	Dave

query I
PRAGMA lpts_check('SELECT id, name FROM users ORDER BY age DESC, name ASC');
----
true

# --- ORDER BY string column ---

query I
PRAGMA lpts_exec('SELECT name FROM users ORDER BY name ASC');
----
Alice
Bob
Carol
Dave
Eve

query I
PRAGMA lpts_check('SELECT name FROM users ORDER BY name ASC');
----
true

# --- LIMIT only: return first N rows ---

query II
PRAGMA lpts_exec('SELECT id, name FROM users ORDER BY id LIMIT 3');
----
1	Alice
2	Bob
3	Carol

query I
PRAGMA lpts_check('SELECT id, name FROM users ORDER BY id LIMIT 3');
----
true

# --- LIMIT 1: single row result ---

query II
PRAGMA lpts_exec('SELECT id, name FROM users ORDER BY id LIMIT 1');
----
1	Alice

query I
PRAGMA lpts_check('SELECT id, name FROM users ORDER BY id LIMIT 1');
----
true

# --- LIMIT larger than row count: returns all rows ---

query II
PRAGMA lpts_exec('SELECT id, name FROM users ORDER BY id LIMIT 100');
----
1	Alice
2	Bob
3	Carol
4	Dave
5	Eve

query I
PRAGMA lpts_check('SELECT id, name FROM users ORDER BY id LIMIT 100');
----
true

# --- LIMIT 0: empty result ---

query II
PRAGMA lpts_exec('SELECT id, name FROM users ORDER BY id LIMIT 0');
----

query I
PRAGMA lpts_check('SELECT id, name FROM users ORDER BY id LIMIT 0');
----
true

# --- LIMIT with OFFSET: skip first N rows ---

query II
PRAGMA lpts_exec('SELECT id, name FROM users ORDER BY id LIMIT 2 OFFSET 2');
----
3	Carol
4	Dave

query I
PRAGMA lpts_check('SELECT id, name FROM users ORDER BY id LIMIT 2 OFFSET 2');
----
true

# --- OFFSET only (LIMIT larger than count): skip first row ---

query II
PRAGMA lpts_exec('SELECT id, name FROM users ORDER BY id LIMIT 100 OFFSET 4');
----
5	Eve

query I
PRAGMA lpts_check('SELECT id, name FROM users ORDER BY id LIMIT 100 OFFSET 4');
----
true

# --- OFFSET past end of result: empty ---

query II
PRAGMA lpts_exec('SELECT id, name FROM users ORDER BY id LIMIT 10 OFFSET 10');
----

query I
PRAGMA lpts_check('SELECT id, name FROM users ORDER BY id LIMIT 10 OFFSET 10');
----
true

# --- ORDER BY + LIMIT combined: top-N pattern ---

query II
PRAGMA lpts_exec('SELECT id, name FROM users ORDER BY age DESC, name ASC LIMIT 3');
----
3	Carol
1	Alice
5	Eve

query I
PRAGMA lpts_check('SELECT id, name FROM users ORDER BY age DESC, name ASC LIMIT 3');
----
true

# --- ORDER BY after GROUP BY: sort aggregate results ---

query II
PRAGMA lpts_exec('SELECT age, count(*) FROM users GROUP BY age ORDER BY age ASC');
----
25	2
30	2
35	1

query I
PRAGMA lpts_check('SELECT age, count(*) FROM users GROUP BY age ORDER BY age ASC');
----
true

# --- ORDER BY on empty table: no rows ---

statement ok
CREATE TABLE empty_tbl (x INTEGER, y VARCHAR);

query II
PRAGMA lpts_exec('SELECT x, y FROM empty_tbl ORDER BY x DESC');
----

query I
PRAGMA lpts_check('SELECT x, y FROM empty_tbl ORDER BY x DESC');
----
true
