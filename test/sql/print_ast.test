# name: test/sql/print_ast.test
# description: test print_ast_query table function
# group: [sql]

require lpts

statement ok
CREATE TABLE users (id INTEGER, name VARCHAR, age INTEGER);

statement ok
CREATE TABLE orders (id INTEGER, user_id INTEGER, amount DECIMAL);

# Simple select — should produce Project → Get
query I
SELECT replace(ast, chr(10), ' | ') FROM print_ast_query('SELECT * FROM users');
----
Project (table_index=1, expressions=3) |   t1_id <- t0_id |   t1_name <- t0_name |   t1_age <- t0_age |   Get memory.main.users (table_index=0) |     columns: [id, name, age]

# Select with filter — should produce Project → Filter → Get
query I
SELECT replace(ast, chr(10), ' | ') FROM print_ast_query('SELECT * FROM users WHERE age > 25');
----
Project (table_index=1, expressions=3) |   t1_id <- t0_id |   t1_name <- t0_name |   t1_age <- t0_age |   Filter (conditions=1) |     cond[0]: (t0_age) > (CAST(25 AS INTEGER)) |     Get memory.main.users (table_index=0) |       columns: [age, id, name]

# Join — should produce Project → Aggregate → Join → Get + Get
query I
SELECT replace(ast, chr(10), ' | ') FROM print_ast_query('SELECT u.name, sum(o.amount) FROM users u JOIN orders o ON u.id = o.user_id GROUP BY u.name');
----
Project (table_index=2, expressions=2) |   t2_name <- t3_name |   t2_aggregate_0 <- t4_aggregate_0 |   Aggregate (groups=1, aggregates=1) |     group_by: [t0_name] |     t4_aggregate_0 <- sum(t1_amount) |     Join (INNER, conditions=1) |       on: (t0_id = t1_user_id) |       Get memory.main.users (table_index=0) |         columns: [id, name] |       Get memory.main.orders (table_index=1) |         columns: [user_id, amount]
