# name: test/sql/union.test
# description: test lpts with UNION ALL queries
# group: [sql]

require lpts

statement ok
CREATE TABLE users (id INTEGER, name VARCHAR);

statement ok
CREATE TABLE orders (id INTEGER, user_id INTEGER, amount DECIMAL);

statement ok
CREATE TABLE staff (id INTEGER, dept VARCHAR, salary INTEGER);

statement ok
INSERT INTO users VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Carol');

statement ok
INSERT INTO orders VALUES (1, 1, 100.0), (2, 2, 200.0), (3, 1, 150.0);

statement ok
INSERT INTO staff VALUES (1, 'eng', 50000), (2, 'sales', 60000);

# --- UNION ALL same table: duplicates rows are preserved ---

query II rowsort
PRAGMA lpts_exec('SELECT id, name FROM users UNION ALL SELECT id, name FROM users');
----
1	Alice
1	Alice
2	Bob
2	Bob
3	Carol
3	Carol

query I
PRAGMA lpts_check('SELECT id, name FROM users UNION ALL SELECT id, name FROM users');
----
true

# --- UNION ALL different tables with compatible schema ---

query II rowsort
PRAGMA lpts_exec('SELECT id, name FROM users UNION ALL SELECT id, dept FROM staff');
----
1	Alice
1	eng
2	Bob
2	sales
3	Carol

query I
PRAGMA lpts_check('SELECT id, name FROM users UNION ALL SELECT id, dept FROM staff');
----
true

# --- UNION ALL with WHERE on each branch independently ---

query II rowsort
PRAGMA lpts_exec('SELECT id, name FROM users WHERE id > 1 UNION ALL SELECT id, dept FROM staff WHERE salary > 55000');
----
2	Bob
2	sales
3	Carol

query I
PRAGMA lpts_check('SELECT id, name FROM users WHERE id > 1 UNION ALL SELECT id, dept FROM staff WHERE salary > 55000');
----
true

# --- UNION ALL where one branch is empty after filter ---

query II rowsort
PRAGMA lpts_exec('SELECT id, name FROM users WHERE id > 100 UNION ALL SELECT id, dept FROM staff');
----
1	eng
2	sales

query I
PRAGMA lpts_check('SELECT id, name FROM users WHERE id > 100 UNION ALL SELECT id, dept FROM staff');
----
true

# --- UNION ALL where both branches produce data ---

query I
PRAGMA lpts_check('SELECT id FROM users UNION ALL SELECT id FROM orders');
----
true

# --- UNION ALL with JOIN on one branch ---

query II rowsort
PRAGMA lpts_exec('SELECT u.id, u.name FROM users u INNER JOIN orders o ON u.id = o.user_id UNION ALL SELECT u.id, u.name FROM users u INNER JOIN orders o ON u.id = o.user_id');
----
1	Alice
1	Alice
1	Alice
1	Alice
2	Bob
2	Bob

query I
PRAGMA lpts_check('SELECT u.id, u.name FROM users u INNER JOIN orders o ON u.id = o.user_id UNION ALL SELECT u.id, u.name FROM users u INNER JOIN orders o ON u.id = o.user_id');
----
true

# --- UNION ALL with aggregate on top: group after combining both branches ---

query II rowsort
PRAGMA lpts_exec('SELECT name, SUM(amount) FROM (SELECT u.name, o.amount FROM users u INNER JOIN orders o ON u.id = o.user_id UNION ALL SELECT u.name, o.amount FROM users u INNER JOIN orders o ON u.id = o.user_id) GROUP BY name');
----
Alice	500.0
Bob	400.0

query I
PRAGMA lpts_check('SELECT name, SUM(amount) FROM (SELECT u.name, o.amount FROM users u INNER JOIN orders o ON u.id = o.user_id UNION ALL SELECT u.name, o.amount FROM users u INNER JOIN orders o ON u.id = o.user_id) GROUP BY name');
----
true

# --- UNION ALL count: total row count is sum of both branches ---

query I
PRAGMA lpts_exec('SELECT count(*) FROM (SELECT id FROM users UNION ALL SELECT id FROM staff)');
----
5

query I
PRAGMA lpts_check('SELECT count(*) FROM (SELECT id FROM users UNION ALL SELECT id FROM staff)');
----
true

# --- UNION ALL with filter on the aggregate result ---

query I
PRAGMA lpts_check('SELECT name, SUM(amount) FROM (SELECT u.name, o.amount FROM users u INNER JOIN orders o ON u.id = o.user_id UNION ALL SELECT u.name, o.amount FROM users u INNER JOIN orders o ON u.id = o.user_id) GROUP BY name HAVING SUM(amount) > 400');
----
true

# --- Three-way UNION ALL ---

query I
PRAGMA lpts_check('SELECT id FROM users UNION ALL SELECT id FROM staff UNION ALL SELECT id FROM orders');
----
true

# UNION ALL with duplicate column names (tests column_map scoping)
query I
PRAGMA lpts_check('SELECT u.id, u.name FROM users u INNER JOIN orders o ON u.id = o.user_id UNION ALL SELECT s.id, s.dept FROM staff s INNER JOIN orders o ON s.id = o.user_id');
----
true

# 3-way UNION ALL (N-ary, tests chaining in AstFlattener)
query I
PRAGMA lpts_check('SELECT id FROM users UNION ALL SELECT id FROM staff UNION ALL SELECT user_id FROM orders');
----
true

# 4-way UNION ALL
statement ok
CREATE TABLE extra (val INTEGER);

statement ok
INSERT INTO extra VALUES (99);

query I
PRAGMA lpts_check('SELECT id FROM users UNION ALL SELECT id FROM staff UNION ALL SELECT user_id FROM orders UNION ALL SELECT val FROM extra');
----
true
